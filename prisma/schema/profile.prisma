model Profile {
  id         String     @id @default(uuid())
  userId     String     @unique
  name       String?
  email      String?
  image      String?
  bio        String?
  avatar     String?
  coverImage String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  bookmark   Bookmark[]
  favorite   Favorite[]
  user       User       @relation(fields: [userId], references: [id])
  medias     Media[]    @relation("MediaProfiles")

  @@map("profile")
}

model Bookmark {
  id        String   @id @default(uuid())
  userId    String
  mediaId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  profileId String?
  media     Media    @relation(fields: [mediaId], references: [id])
  profile   Profile? @relation(fields: [profileId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("bookmark")
}

model Favorite {
  id        String   @id @default(uuid())
  userId    String
  mediaId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  profileId String?
  media     Media    @relation(fields: [mediaId], references: [id])
  profile   Profile? @relation(fields: [profileId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("favorite")
}
