model Media {
  id            String      @id @default(uuid())
  title         String
  description   String
  type          MediaType
  releaseDate   DateTime
  genre         String[]
  coverImage    String
  trailerUrl    String?
  streamUrl     String?
  averageRating Float       @default(0)
  totalRatings  Int         @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  createdById   String?
  watchList     WatchList[]
  bookmarks     Bookmark[]
  favorites     Favorite[]
  createdBy     User?       @relation("MediaAddedBy", fields: [createdById], references: [id])
  ratings       Rating[]
  reviews       Review[]
  genres        Genre[]     @relation("MediaGenres")
  profiles      Profile[]   @relation("MediaProfiles")

  @@index([title, type])
  @@map("media")
}
