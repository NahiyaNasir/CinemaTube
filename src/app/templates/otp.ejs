<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>OTP Verification</title>

  <style>
    /* Mobile responsive */
    @media only screen and (max-width: 600px) {
      .container {
        width: 100% !important;
        padding: 15px !important;
      }
      .otp {
        font-size: 28px !important;
        letter-spacing: 6px !important;
      }
      .button {
        width: 100% !important;
      }
    }
  </style>
</head>

<body style="margin:0; padding:0; background-color:#f6f9fc; font-family: Arial, sans-serif;">

  <table width="100%" cellpadding="0" cellspacing="0">
    <tr>
      <td align="center">

        <!-- Card -->
        <table class="container" width="500" cellpadding="0" cellspacing="0"
          style="background:#ffffff; margin-top:40px; border-radius:12px; padding:30px; box-shadow:0 5px 20px rgba(0,0,0,0.05);">

          <!-- Logo -->
          <tr>
            <td align="center" style="padding-bottom:20px;">
              <h2 style="margin:0; color:#111;">🚀 Your App</h2>
            </td>
          </tr>

          <!-- Greeting -->
          <tr>
            <td style="font-size:16px; color:#333;">
              Hi <strong><%= name %></strong>,
            </td>
          </tr>

          <!-- Message -->
          <tr>
            <td style="padding:15px 0; font-size:15px; color:#555;">
              Use the following OTP to complete your verification:
            </td>
          </tr>

          <!-- OTP Box -->
          <tr>
            <td align="center">
              <div class="otp"
                style="font-size:32px; letter-spacing:8px; font-weight:bold; color:#111; background:#f1f5f9; padding:15px 25px; border-radius:8px; display:inline-block;">
                <%= otp %>
              </div>
            </td>
          </tr>

          <!-- Expiry -->
          <tr>
            <td align="center" style="padding-top:10px; font-size:13px; color:#888;">
              Expires in <%= expiry %> minutes
            </td>
          </tr>

          <!-- Button -->
          <tr>
            <td align="center" style="padding:25px 0;">
              <a href="<%= verifyLink %>" class="button"
                style="background:#4f46e5; color:#fff; padding:12px 25px; text-decoration:none; border-radius:6px; font-size:14px; display:inline-block;">
                Verify Now
              </a>
            </td>
          </tr>

          <!-- Warning -->
          <tr>
            <td style="font-size:13px; color:#777;">
              If you didn’t request this, you can safely ignore this email.
            </td>
          </tr>

          <!-- Divider -->
          <tr>
            <td style="padding:20px 0;">
              <hr style="border:none; border-top:1px solid #eee;" />
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td align="center" style="font-size:12px; color:#999; line-height:1.6;">
              
              © <%= new Date().getFullYear() %>Cinema Tube <br/>

              <a href="mailto:support@yourapp.com" style="color:#666; text-decoration:none;">
                support@yourapp.com
              </a>
              <br/><br/>

              <a href="#" style="margin:0 5px; color:#666; text-decoration:none;">Facebook</a>
              |
              <a href="#" style="margin:0 5px; color:#666; text-decoration:none;">Twitter</a>
              |
              <a href="#" style="margin:0 5px; color:#666; text-decoration:none;">LinkedIn</a>

            </td>
          </tr>

        </table>

      </td>
    </tr>
  </table>

</body>
</html>